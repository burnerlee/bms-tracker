# Minutes between each crawler run (default: 1)
CRON_INTERVAL_MINUTES=1

# BookMyShow city slug (e.g. mumbai, delhi-ncr, bengaluru)
BMS_CITY=bengaluru

# Movie name to search on BookMyShow
MOVIE_NAME=Dhurandhar The Revenge

# Date to check for ticket availability (YYYY-MM-DD)
TARGET_DATE=2026-03-18

# Optional: skip search and use this event ID (from the movie's buytickets URL).
# If set, the crawler opens the buytickets page directly. Set BMS_MOVIE_SLUG too
# or it will be derived from MOVIE_NAME.
BMS_EVENT_ID=ET00478890
BMS_MOVIE_SLUG=dhurandhar-the-revenge

# Optional: Slack notification when tickets are available.
# Create an Incoming Webhook in your Slack workspace (see README).
# SLACK_WEBHOOK_URL=
